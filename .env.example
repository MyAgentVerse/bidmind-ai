# Application Configuration
APP_NAME=BidMind AI API
ENVIRONMENT=development
DEBUG=true

# Database Configuration (Railway provides this automatically)
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/bidmind_ai

# Security (MUST change in production — generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production

# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25
ALLOWED_EXTENSIONS=pdf,docx

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
